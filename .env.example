# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" only for local/dev: skip admin approval — pending members can sign in,
# and new registrations are saved as active immediately.
# Production: leave unset or "false" and approve members in /admin.
# Also disable "Confirm email" in Supabase: Authentication → Providers → Email.
# NEXT_PUBLIC_BYPASS_MEMBERSHIP_APPROVAL=true

# n8n webhook — welcome email when admin approves a member (server-only)
N8N_MEMBER_APPROVED_WEBHOOK_URL=
# Optional: sent as Authorization: Bearer <secret>
# N8N_WEBHOOK_SECRET=
