# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" only for local/dev: skip admin approval — pending members can sign in,
# and new registrations are saved as active when email confirmation returns a session.
# Production: leave unset or "false" and approve members in /admin.
# NEXT_PUBLIC_BYPASS_MEMBERSHIP_APPROVAL=true
