# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Early launch: set "true" so new registrations are active immediately (no admin queue)
# and pending members can sign in. Set "false" later to require /admin approval again.
# Also disable "Confirm email" in Supabase: Authentication → Providers → Email.
NEXT_PUBLIC_BYPASS_MEMBERSHIP_APPROVAL=true

# n8n webhook — welcome email when a member is approved (admin or auto on register)
N8N_MEMBER_APPROVED_WEBHOOK_URL=
# Optional: sent as Authorization: Bearer <secret>
# N8N_WEBHOOK_SECRET=
